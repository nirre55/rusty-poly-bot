# Mode d'exécution : dry-run | market | limit
EXECUTION_MODE=dry-run

# Binance WebSocket
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
SYMBOL=btcusdt
INTERVAL=5m

# Montant par trade en USDC
TRADE_AMOUNT_USDC=10.0

# Polymarket CLOB API (requis pour mode market/limit)
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# Clé privée EVM (hex, avec ou sans "0x"). Requise pour mode market.
POLYMARKET_PRIVATE_KEY=

# Adresse funder Polymarket (proxy/safe) si différente de l'EOA signataire.
# POLYMARKET_FUNDER=

# Signature type Polymarket: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE.
# POLYMARKET_SIGNATURE_TYPE=2

# Stratégie de trading (défaut: three_candle_rsi7_reversal)
STRATEGY=three_candle_rsi7_reversal

# Seuils RSI (défaut: 35 / 65)
RSI_OVERSOLD=35.0
RSI_OVERBOUGHT=65.0

# Préfixe slug Polymarket (défaut: btc-updown-5m)
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Martingale : multiplicateur après chaque loss (1.0 = désactivé)
MARTINGALE_MULTIPLIER=1.0
# Martingale : montant maximum en USDC (0.0 = pas de plafond)
MARTINGALE_MAX_AMOUNT=0.0

# Dossier des logs
LOGS_DIR=logs
